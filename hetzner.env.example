# ECO-IA environment — legacy Hetzner template (kept for compatibility)
# Use .env.example at project root for OVHcloud setup
ENVIRONMENT=production
DEBUG=false
ECO_IA_API_KEY=change-me
ECO_IA_ADMIN_KEY=change-me-admin
DATABASE_URL=postgresql://eco_ia:eco_ia_password@postgres:5432/eco_ia
REDIS_URL=redis://redis:6379/0
POSTGRES_PASSWORD=eco_ia_password
LLM_PROVIDER=openai
OPENAI_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAILS=
HETZNER_STORAGE_BOX_HOST=
HETZNER_STORAGE_BOX_USER=
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GF_SECURITY_ADMIN_PASSWORD=change-me
BACKUP_RETENTION_DAYS=30
MAX_BRUTE_FORCE_ATTEMPTS=10
AUTO_BLOCK_INTRUDERS=true
